# 4. Scanner Logic (SPY Only)
@st.cache_data(ttl=30)
def scan_spy_puts():
    ticker = yf.Ticker('SPY')
    hist = ticker.history(period='1d')
    if hist.empty: return pd.DataFrame()
    spot = hist['Close'].iloc[-1]
    results = []
    for exp in ticker.options[:10]:
        chain = ticker.option_chain(exp)
        puts = chain.puts
        puts['spot'], puts['expiry'] = spot, exp
        puts['moneyness'] = (puts['strike'] / spot) * 100
        # Filters: Vol > 100, IV > 50%, Price < $0.30, OTM > 110%
        mask = (puts['volume'] > 100) & (puts['impliedVolatility'] > 0.5) & (puts['lastPrice'] < 0.30) & (puts['moneyness'] < 90)
        filtered = puts[mask].copy()
        if not filtered.empty:
            filtered['sudden_spike'] = filtered['volume'] > (filtered['openInterest'] * 2)
            results.append(filtered)
    return pd.concat(results, ignore_index=True) if results else pd.DataFrame()

